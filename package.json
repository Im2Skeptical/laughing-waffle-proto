{
  "name": "laughing-waffle-proto",
  "version": "1.0.0",
  "description": "Sparse prototype fork for Civilization Survivor core-system rework",
  "type": "module",
  "main": "index.html",
  "scripts": {
    "start": "serve",
    "build": "node scripts/build-pages.mjs",
    "check:build": "node scripts/build-pages.mjs",
    "test": "node -e \"console.log('No legacy test scripts configured.')\"",
    "verify": "npm run build && npm run test:world && npm run test:regional-practices && npm run test:map-lab && npm run test:determinism && npm run test:debug-overrides",
    "test:world": "node src/model/tests/world-state.js",
    "test:regional-practices": "node src/model/tests/regional-practices.js",
    "test:map-lab": "node src/model/tests/map-lab-draft.js",
    "test:determinism": "node --input-type=module -e \"import {runDeterminismSuite} from './src/model/tests/determinism.js'; if(!runDeterminismSuite()) process.exit(1)\"",
    "test:debug-overrides": "node --input-type=module -e \"import {runDebugOverrideSuite} from './src/model/tests/debug-overrides.js'; if(!runDebugOverrideSuite()) process.exit(1)\"",
    "probe:settlement": "node scripts/settlement-browser-probe.mjs",
    "probe:settlement:quiet": "node scripts/settlement-browser-probe.mjs",
    "probe:settlement:verbose": "node scripts/settlement-browser-probe.mjs --verbose",
    "probe:map-lab": "node scripts/map-lab-browser-probe.mjs"
  },
  "keywords": [
    "html",
    "css"
  ],
  "author": "Ives van Hoorne",
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.25.9",
    "playwright": "^1.59.1",
    "serve": "11.2.0"
  }
}
